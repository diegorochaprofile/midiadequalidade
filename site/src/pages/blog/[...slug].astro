---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} — Mídia de Qualidade`} description={post.data.description}>
  <div class="wrap" style="padding-top:150px;max-width:780px">
    <article style="padding:0 0 110px">
      <a href="/blog" class="eyebrow">← Voltar ao blog</a>
      <h1 class="sec-title" style="margin:22px 0 12px;font-size:clamp(28px,4vw,44px)">{post.data.title}</h1>
      <p class="muted" style="margin-bottom:44px">{post.data.date.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}</p>
      <div class="prose"><Content /></div>
    </article>
  </div>
</Layout>
