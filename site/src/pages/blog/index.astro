---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title="Blog — Mídia de Qualidade" description="Ideias, método e bastidores sobre presença digital, marketing e tecnologia.">
  <div class="wrap" style="padding-top:150px">
    <section style="padding-top:0">
      <span class="eyebrow">Blog</span>
      <h1 class="sec-title" style="margin-top:18px">Ideias e bastidores.</h1>
      <p class="sec-intro">Conteúdo sobre presença digital, marketing e tecnologia — direto ao ponto.</p>

      <div class="grid g-3" style="margin-top:54px">
        {posts.map((p) => (
          <a href={`/blog/${p.id}/`} class="card" style="display:block">
            <span class="tag">{p.data.date.toLocaleDateString('pt-BR')}</span>
            <h3 style="margin-top:8px;font-size:19px;font-weight:700">{p.data.title}</h3>
            <p style="margin-top:8px">{p.data.description}</p>
          </a>
        ))}
        {posts.length === 0 && <p class="muted">Em breve, os primeiros artigos.</p>}
      </div>
    </section>
  </div>
</Layout>
